{
  "pattern": "layered",
  "roles": {
    "layers": [
      {
        "name": "data",
        "slot": {
          "paths": [
            "src/registry.ts",
            "src/ports.ts"
          ]
        }
      },
      {
        "name": "application",
        "slot": {
          "paths": [
            "src/spawn.ts",
            "src/commands.ts",
            "src/host.ts",
            "src/rebuild.ts"
          ]
        }
      },
      {
        "name": "presentation",
        "slot": {
          "paths": [
            "src/cli.ts",
            "src/index.ts",
            "ui",
            "app"
          ]
        }
      }
    ]
  },
  "tests":   { "paths": ["tests"] },
  "scripts": { "paths": ["scripts"] },
  "docs":    { "paths": ["docs"] }
}
